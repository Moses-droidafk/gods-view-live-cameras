<!DOCTYPE html>
<html>
<head>
    <title>Admin Dashboard</title>

    <style>

        body{
            font-family:Arial,sans-serif;
            margin:0;
            background:#0f172a;
            color:white;
        }

        header{
            background:#1e293b;
            text-align:center;
            padding:25px;
        }

        .container{
            width:95%;
            margin:20px auto;
        }

        .stats{

            display:grid;

            grid-template-columns:
                repeat(auto-fit,minmax(220px,1fr));

            gap:20px;

            margin-bottom:30px;

        }

        .card{

            background:#1e293b;
            padding:25px;
            border-radius:15px;

            text-align:center;

            box-shadow:
                0 5px 15px rgba(0,0,0,.4);

        }

        .card h1{
            color:#60a5fa;
            font-size:40px;
        }

        .buttons{
            margin-bottom:20px;
        }

        .buttons a{

            background:#2563eb;
            color:white;

            padding:12px 15px;

            text-decoration:none;

            border-radius:8px;

            margin-right:10px;

        }

        table{

            width:100%;
            border-collapse:collapse;

            background:#1e293b;

        }

        th, td{

            border:1px solid #334155;

            padding:12px;

            text-align:left;

        }

        th{
            background:#2563eb;
        }

        .edit{

            background:#16a34a;
            color:white;

            padding:8px;

            text-decoration:none;

            border-radius:5px;

        }

        .delete{

            background:#dc2626;
            color:white;

            padding:8px;

            text-decoration:none;

            border-radius:5px;

        }

    </style>

</head>

<body>

<header>

    <h1>🛠️ God's View Admin Dashboard</h1>

</header>

<div class="container">

    <div class="stats">

        <div class="card">

            <h1><%= stats.totalCameras %></h1>

            <p>Total Cameras</p>

        </div>

        <div class="card">

            <h1><%= stats.totalUsers %></h1>

            <p>Total Users</p>

        </div>

        <div class="card">

            <h1><%= stats.totalFavorites %></h1>

            <p>Total Favorites</p>

        </div>

        <div class="card">

            <h1><%= stats.onlineCameras %></h1>

            <p>Online Cameras</p>

        </div>

        <div class="card">

            <h1><%= stats.offlineCameras %></h1>

            <p>Offline Cameras</p>

        </div>

    </div>

    <div class="buttons">

        <a href="/admin/add-camera">

            ➕ Add Camera

        </a>

        <a href="/admin/users">

            👥 Users

        </a>

        <a href="/admin/check-cameras">

            📡 Check Cameras

        </a>

    </div>

    <table>

        <tr>

            <th>ID</th>
            <th>Name</th>
            <th>Location</th>
            <th>Status</th>
            <th>Actions</th>

        </tr>

        <% cameras.forEach(camera => { %>

        <tr>

            <td><%= camera.id %></td>

            <td><%= camera.name %></td>

            <td><%= camera.location %></td>

            <td><%= camera.status %></td>

            <td>

                <a
                    class="edit"
                    href="/admin/edit-camera/<%= camera.id %>">

                    Edit

                </a>

                <a
                    class="delete"
                    href="/admin/delete-camera/<%= camera.id %>">

                    Delete

                </a>

            </td>

        </tr>

        <% }) %>

    </table>

</div>

</body>
</html>